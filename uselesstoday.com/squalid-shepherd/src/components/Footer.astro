---
// Footer band — DESIGN footer tokens, caption-mono eyebrows.
const EMAIL = "prasad.rajeshwar@gmail.com";

const cols = [
  {
    head: "The site",
    links: [
      { label: "The wall", href: "/#directory" },
      { label: "Surprise me", href: "#", attr: "data-surprise" },
      { label: "About us", href: "/about/" },
      { label: "Contact us", href: "/contact/" },
    ],
  },
  {
    head: "Games",
    links: [
      { label: "Ludo", href: "/ludo/" },
      { label: "Chess", href: "/chess/" },
      { label: "Carrom", href: "/caram/" },
      { label: "Bubble Shooter", href: "/bubble/" },
      { label: "Valentine", href: "/valentine/" },
    ],
  },
  {
    head: "Contribute",
    links: [
      { label: "Submit a site", href: `mailto:${EMAIL}?subject=Useless%20site%20suggestion` },
      { label: "Report a broken link", href: `mailto:${EMAIL}?subject=Broken%20link` },
    ],
  },
  {
    head: "Legal",
    links: [
      { label: "Privacy Policy", href: "/privacy/" },
      { label: "Terms & Conditions", href: "/terms/" },
      { label: "DMCA Notice", href: "/dmca/" },
    ],
  },
];
---

<footer id="footer" class="border-t border-hairline bg-canvas">
  <div class="mx-auto max-w-[1200px] px-4 py-16 sm:px-6">
    <div class="grid gap-10 md:grid-cols-2 lg:grid-cols-[1.4fr_1fr_1fr_1fr_1fr]">
      <div class="max-w-xs">
        <div class="flex items-center gap-2">
          <span
            class="grid size-6 place-items-center rounded-sm bg-ink text-[13px] leading-none text-on-primary"
            aria-hidden="true">u</span
          >
          <span class="text-[15px] font-semibold tracking-tight">uselesstoday.com</span>
        </div>
        <p class="mt-3 text-[14px] leading-5 text-body">
          A wall of beautifully pointless websites. Time, generously wasted
          since today.
        </p>
      </div>

      {
        cols.map((c) => (
          <div>
            <p class="font-mono text-[12px] uppercase tracking-wide text-mute">{c.head}</p>
            <ul class="mt-4 space-y-2.5">
              {c.links.map((l) => (
                <li>
                  <a
                    href={l.href}
                    {...(l.attr ? { [l.attr]: "" } : {})}
                    class="text-[14px] text-body transition-colors hover:text-ink"
                  >
                    {l.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <div
      class="mt-12 flex flex-col gap-2 border-t border-hairline pt-6 text-[13px] text-mute sm:flex-row sm:items-center sm:justify-between"
    >
      <p>© {new Date().getFullYear()} uselesstoday.com — go do something productive.</p>
      <p class="font-mono text-[12px]">Built for wasting time. On purpose.</p>
    </div>
  </div>
</footer>
