---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
---

<Layout
  title="Something Went Wrong (500) — Useless Today"
  description="Our server tripped over its own uselessness. Try again in a moment, head back to the wall, or hit Surprise me."
  path="/500/"
  noindex
>
  <Nav />
  <main id="main-content" class="relative isolate overflow-hidden">
    <div
      class="mesh-soft pointer-events-none absolute inset-0 -z-10 opacity-90"
      aria-hidden="true"
    >
    </div>
    <div
      class="mx-auto flex max-w-[640px] flex-col items-center px-4 py-28 text-center sm:px-6 sm:py-36"
    >
      <p
        class="inline-flex items-center gap-2 rounded-full border border-hairline bg-canvas/70 px-3 py-1 font-mono text-[12px] uppercase tracking-wide text-body backdrop-blur"
      >
        Error 500
      </p>
      <h1
        class="mt-6 text-[64px] font-semibold leading-none tracking-[-0.045em] text-ink sm:text-[96px]"
      >
        500
      </h1>
      <p class="mt-5 max-w-[460px] text-[18px] leading-7 text-body">
        Something on our end tripped over its own uselessness. This one's not
        your fault — try again in a moment, or wander somewhere that still works.
      </p>

      <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
        <a
          href="/"
          class="inline-flex h-12 items-center rounded-full bg-ink px-6 text-[16px] font-medium text-on-primary shadow-[var(--shadow-card)] transition-transform hover:scale-[1.03] active:scale-95"
        >
          Back to the wall
        </a>
        <button
          type="button"
          data-surprise
          class="inline-flex h-12 items-center gap-2 rounded-full border border-hairline bg-canvas px-6 text-[16px] font-medium text-ink transition-colors hover:bg-canvas-soft-2"
        >
          Surprise me
          <span aria-hidden="true">→</span>
        </button>
      </div>

      <p class="mt-8 font-mono text-[12px] text-mute">
        Still stuck? Email
        <a href="mailto:prasad.rajeshwar@gmail.com" class="underline underline-offset-2 hover:text-ink"
          >prasad.rajeshwar@gmail.com</a
        >.
      </p>
    </div>
  </main>
  <Footer />
</Layout>
